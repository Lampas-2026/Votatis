# 클라이언트에 노출되는 변수는 PUBLIC_ prefix 필요 (Astro 규칙)

# intake-api 엔드포인트. 로컬 wrangler dev 기본값.
PUBLIC_API_BASE_URL="http://localhost:8787"

# Turnstile sitekey. 비워두면 Cloudflare 테스트키(항상 통과)를 쓴다.
#   로컬/개발: 1x00000000000000000000AA (항상 통과)
#   운영:      0x4AAAAAADhXh1OGOie5kiwQ
PUBLIC_TURNSTILE_SITEKEY="1x00000000000000000000AA"

# base path. 빌드 타임에만 쓰인다(astro.config).
#   Cloudflare Pages / 커스텀 도메인: /
#   GitHub Pages 프로젝트 페이지:     /<repo>/
PUBLIC_BASE_PATH="/"
