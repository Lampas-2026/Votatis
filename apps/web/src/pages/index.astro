    <script>
      // mobile nav
      const hd = document.getElementById("hd");
      const hamb = document.getElementById("hamb");
      hamb?.addEventListener("click", () => hd?.classList.toggle("open"));
      document.querySelectorAll(".menu a").forEach((a) => {
        a.addEventListener("click", () => hd?.classList.remove("open"));
      });

      // scroll reveal + bar fill
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add("in");
              if (e.target.querySelector(".fill") || e.target.classList.contains("chart-card")) {
                e.target.querySelectorAll(".fill").forEach((f) => {
                  (f as HTMLElement).style.width = (f as HTMLElement).dataset.w + "%";
                });
              }
              io.unobserve(e.target);
            }
          });
        },
        { threshold: 0.14 },
      );
      document.querySelectorAll(".reveal").forEach((el) => io.observe(el));
    </script>
