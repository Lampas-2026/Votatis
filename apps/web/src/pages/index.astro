---
import Base from "../layouts/Base.astro";
import ReportForm from "../components/ReportForm.tsx";
---

<Base title="제보하기 · Votatis">
  <main class="mx-auto max-w-2xl px-4 py-10">
    <header class="mb-8">
      <h1 class="text-2xl font-bold tracking-tight">제보하기</h1>
      <p class="mt-2 text-sm text-gray-600">
        분산되어 사라지는 증거와 제보를 검증 가능한 형태로 모읍니다. 출처 또는 첨부 중
        최소 하나는 반드시 필요합니다.
      </p>
    </header>
    <!-- 인터랙션이 필요한 폼만 React island 로 하이드레이션 (콘텐츠는 zero-JS) -->
    <ReportForm client:load />
  </main>
</Base>
