---
// 랜딩 페이지 — votatis.html 시안 이식(자체 디자인 시스템 CSS 유지, Tailwind/Base 비사용).
// 제보 진입점은 모두 /report 로 보낸다(base path 반영).
const reportHref = `${import.meta.env.BASE_URL}report`;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Votatis · 선거 제보 검증 아카이브</title>
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css"
    />
    <style is:global>
      :root {
        --ink: #16181d;
        --paper: #ffffff;
        --mist: #fafafb;
        --line: #ecedf0;
        --ash: #6b7280;
        --ash-soft: #9ca3af;
        --signal: #e0342a;
        --signal-press: #c5281f;
        --signal-soft: #fbeae8;
        --signal-mid: #f2938b;
        --slate: #5b6573;
        --r-sm: 8px;
        --r-md: 12px;
        --r-lg: 18px;
        --shadow: 0 1px 2px rgba(16, 18, 29, 0.04), 0 12px 32px rgba(16, 18, 29, 0.06);
        --shadow-soft: 0 1px 2px rgba(16, 18, 29, 0.04), 0 6px 18px rgba(16, 18, 29, 0.05);
        --maxw: 1120px;
        --ease: cubic-bezier(0.22, 0.61, 0.36, 1);
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }
      body {
        font-family: "Pretendard Variable", Pretendard, -apple-system, system-ui, sans-serif;
        color: var(--ink);
        background: var(--paper);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        letter-spacing: -0.01em;
      }
      a { color: inherit; text-decoration: none; }
      img { display: block; max-width: 100%; }
      a:focus-visible, button:focus-visible, .btn:focus-visible {
        outline: 2px solid var(--signal); outline-offset: 3px; border-radius: var(--r-sm);
      }
      .wrap { max-width: var(--maxw); margin: 0 auto; padding: 0 24px; }

      /* ---------- buttons ---------- */
      .btn {
        display: inline-flex; align-items: center; justify-content: center; gap: 6px;
        font-size: 15px; font-weight: 600; padding: 12px 22px; border-radius: var(--r-sm);
        border: 1px solid transparent; cursor: pointer;
        transition: transform 0.15s var(--ease), background 0.15s, border-color 0.15s, color 0.15s;
        white-space: nowrap;
      }
      .btn:active { transform: translateY(1px); }
      .btn-primary { background: var(--signal); color: #fff; }
      .btn-primary:hover { background: var(--signal-press); }
      .btn-ghost { background: #fff; color: var(--ink); border-color: var(--line); }
      .btn-ghost:hover { border-color: #cfd2d8; background: var(--mist); }
      .btn-dark-ghost { background: transparent; color: #fff; border-color: rgba(255, 255, 255, 0.22); }
      .btn-dark-ghost:hover { border-color: rgba(255, 255, 255, 0.5); background: rgba(255, 255, 255, 0.06); }
      .btn-sm { padding: 9px 16px; font-size: 14px; }

      /* ---------- header ---------- */
      header {
        position: sticky; top: 0; z-index: 50; background: rgba(255, 255, 255, 0.82);
        backdrop-filter: saturate(160%) blur(12px); border-bottom: 1px solid var(--line);
      }
      .nav { display: flex; align-items: center; justify-content: space-between; height: 64px; }
      .brand { display: flex; align-items: center; gap: 10px; font-weight: 700; font-size: 18px; }
      .mark {
        width: 30px; height: 30px; border-radius: 8px; background: var(--signal); color: #fff;
        display: grid; place-items: center; font-weight: 800; font-size: 17px;
      }
      .menu { display: flex; align-items: center; gap: 30px; }
      .menu a { font-size: 15px; color: #3b3f47; font-weight: 500; transition: color 0.15s; }
      .menu a:hover { color: var(--signal); }
      .menu .btn { display: none; }
      .menu .btn:hover { color: #fff; }
      .nav-right { display: flex; align-items: center; gap: 14px; }
      .hamb {
        display: none; width: 40px; height: 40px; border: 1px solid var(--line); border-radius: var(--r-sm);
        background: #fff; cursor: pointer; align-items: center; justify-content: center;
      }
      .hamb span { display: block; width: 18px; height: 2px; background: var(--ink); position: relative; }
      .hamb span::before, .hamb span::after { content: ""; position: absolute; left: 0; width: 18px; height: 2px; background: var(--ink); }
      .hamb span::before { top: -6px; }
      .hamb span::after { top: 6px; }

      /* ---------- hero ---------- */
      .hero { padding: 88px 0 56px; text-align: center; overflow: hidden; }
      .eyebrow {
        display: inline-flex; align-items: center; gap: 7px; font-size: 13px; font-weight: 600;
        color: var(--signal); background: var(--signal-soft); padding: 6px 13px; border-radius: 999px; margin-bottom: 22px;
      }
      .eyebrow .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--signal); }
      .hero h1 { font-size: clamp(28px, 5vw, 46px); font-weight: 800; line-height: 1.28; letter-spacing: -0.03em; max-width: 760px; margin: 0 auto; }
      .hero p { margin: 20px auto 0; max-width: 560px; color: var(--ash); font-size: clamp(15px, 2.2vw, 17px); }
      .hero .cta { display: flex; gap: 12px; justify-content: center; margin-top: 34px; flex-wrap: wrap; }

      /* ---------- dashboard mock ---------- */
      .mock-shell { margin: 54px auto 0; max-width: 980px; border-radius: var(--r-lg); border: 1px solid var(--line); background: #fff; box-shadow: var(--shadow); overflow: hidden; }
      .mock-bar { display: flex; align-items: center; gap: 8px; padding: 13px 16px; border-bottom: 1px solid var(--line); background: var(--mist); }
      .lights { display: flex; gap: 6px; }
      .lights i { width: 11px; height: 11px; border-radius: 50%; background: #dfe2e7; display: inline-block; }
      .addr { flex: 1; margin-left: 8px; background: #fff; border: 1px solid var(--line); border-radius: 999px; font-size: 12.5px; color: var(--ash); padding: 6px 14px; text-align: center; }
      /* 사이드바 숨김 중: 복원 시 grid-template-columns 를 208px 1fr 로 되돌린다. */
      .mock-body { display: grid; grid-template-columns: 1fr; min-height: 420px; }
      .side { border-right: 1px solid var(--line); padding: 18px 14px; background: #fff; }
      .side-mark { display: flex; align-items: center; gap: 8px; font-weight: 700; font-size: 15px; padding: 0 6px 14px; }
      .side-mark .mark { width: 24px; height: 24px; font-size: 14px; border-radius: 6px; }
      .side h6 { font-size: 11px; letter-spacing: 0.04em; color: var(--ash-soft); font-weight: 600; padding: 14px 6px 8px; text-transform: uppercase; }
      .side-item { display: flex; align-items: center; gap: 9px; padding: 8px 8px; border-radius: var(--r-sm); font-size: 13.5px; color: #4b5059; font-weight: 500; }
      .side-item.active { background: var(--signal-soft); color: var(--signal); font-weight: 600; }
      .side-item .ic { width: 15px; height: 15px; flex: none; opacity: 0.8; }
      .side-item .num { margin-left: auto; font-size: 12px; color: var(--ash-soft); font-weight: 600; }
      .side-item.active .num { color: var(--signal); }
      .legend-row { display: flex; align-items: center; gap: 8px; padding: 7px 8px; font-size: 13px; color: #4b5059; }
      .legend-row .sw { width: 8px; height: 8px; border-radius: 2px; flex: none; }
      .legend-row .num { margin-left: auto; font-weight: 600; font-size: 12.5px; color: #4b5059; }

      .panel { padding: 20px; min-width: 0; }
      .panel-head h3 { font-size: 18px; font-weight: 700; }
      .panel-head p { font-size: 12.5px; color: var(--ash); margin-top: 2px; }
      .toolbar { display: flex; justify-content: space-between; align-items: center; gap: 10px; margin-bottom: 16px; flex-wrap: wrap; }
      .chips { display: flex; gap: 6px; }
      .chip { font-size: 12px; padding: 5px 11px; border-radius: 999px; border: 1px solid var(--line); color: var(--ash); background: #fff; }
      .chip.on { background: var(--ink); color: #fff; border-color: var(--ink); }
      .stat-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-bottom: 18px; }
      .stat { border: 1px solid var(--line); border-radius: var(--r-md); padding: 13px 14px; }
      .stat .lab { display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--ash); }
      .stat .lab i { width: 6px; height: 6px; border-radius: 50%; display: inline-block; }
      .stat .val { font-size: 26px; font-weight: 800; letter-spacing: -0.02em; margin-top: 6px; }
      .stat .sub { font-size: 11.5px; color: var(--ash-soft); margin-top: 1px; }
      .stat .sub.up { color: var(--signal); }

      .grid-2 { display: grid; grid-template-columns: 1.45fr 1fr; gap: 14px; }
      .card { border: 1px solid var(--line); border-radius: var(--r-md); padding: 16px; }
      .card-h { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 12px; }
      .card-h b { font-size: 14px; font-weight: 700; }
      .card-h a { font-size: 12px; color: var(--ash); }
      table { width: 100%; border-collapse: collapse; font-size: 12.5px; }
      th { text-align: left; color: var(--ash-soft); font-weight: 600; font-size: 11.5px; padding: 0 6px 9px; }
      td { padding: 8px 6px; border-top: 1px solid var(--line); color: #3b3f47; }
      td.t { font-weight: 500; color: var(--ink); }
      .badge { display: inline-flex; align-items: center; gap: 5px; font-size: 11px; font-weight: 600; padding: 3px 9px; border-radius: 999px; white-space: nowrap; }
      .badge i { width: 5px; height: 5px; border-radius: 50%; }
      .b-confirm { background: var(--signal-soft); color: var(--signal); }
      .b-review { background: #fff3f2; color: #d8665e; }
      .b-deny { background: #f1f2f4; color: #4b5059; }
      .b-issue { background: #fdf3e7; color: #b5792a; }
      .avatar { width: 20px; height: 20px; border-radius: 50%; background: #eef0f3; color: #6b7280; font-size: 10px; font-weight: 700; display: inline-grid; place-items: center; }
      .donut-wrap { display: flex; flex-direction: column; align-items: center; gap: 14px; }
      .donut {
        width: 148px; height: 148px; border-radius: 50%; position: relative;
        background: conic-gradient(
          var(--signal) 0 35.2%,
          var(--signal-mid) 35.2% 55.3%,
          #d7dbe0 55.3% 71.4%,
          var(--ink) 71.4% 82.4%,
          var(--ash-soft) 82.4% 91.2%,
          var(--slate) 91.2% 100%
        );
      }
      .donut::after { content: ""; position: absolute; inset: 26px; border-radius: 50%; background: #fff; }
      .donut .center { position: absolute; inset: 0; display: grid; place-content: center; text-align: center; }
      .donut .center b { font-size: 22px; font-weight: 800; }
      .donut .center span { font-size: 10.5px; color: var(--ash); }
      .donut-legend { width: 100%; display: grid; grid-template-columns: 1fr 1fr; gap: 2px 18px; }

      /* ---------- section frame ---------- */
      .section { padding: 84px 0; }
      .section.alt { background: var(--mist); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
      .kicker { font-size: 13px; font-weight: 700; color: var(--signal); letter-spacing: 0.02em; margin-bottom: 14px; }

      /* ---------- verify section ---------- */
      .verify { display: grid; grid-template-columns: 1fr 1.05fr; gap: 56px; align-items: center; }
      .verify h2 { font-size: clamp(26px, 3.6vw, 36px); font-weight: 800; line-height: 1.32; letter-spacing: -0.025em; }
      .verify .lead { color: var(--ash); margin-top: 18px; font-size: 16px; max-width: 420px; }
      .checks { margin-top: 26px; display: flex; flex-direction: column; gap: 14px; }
      .check { display: flex; gap: 12px; align-items: flex-start; font-size: 15px; color: #3b3f47; }
      .check .tick { width: 22px; height: 22px; border-radius: 6px; background: var(--signal-soft); color: var(--signal); display: grid; place-items: center; flex: none; font-size: 13px; font-weight: 800; }
      .check b { color: var(--ink); }

      .record { border: 1px solid var(--line); border-radius: var(--r-lg); background: #fff; box-shadow: var(--shadow-soft); overflow: hidden; }
      .record-bar { display: flex; align-items: center; gap: 8px; padding: 11px 14px; border-bottom: 1px solid var(--line); background: var(--mist); }
      .record-bar .addr { margin-left: 6px; }
      .record-body { padding: 22px; }
      .rec-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px; }
      .rec-id { font-size: 12px; color: var(--ash-soft); font-family: ui-monospace, "SF Mono", Menlo, monospace; }
      .record h4 { font-size: 18px; font-weight: 700; letter-spacing: -0.02em; }
      .record .desc { font-size: 14px; color: var(--ash); margin-top: 8px; }
      .tags { display: flex; gap: 6px; flex-wrap: wrap; margin: 16px 0; }
      .tag { font-size: 12px; color: #4b5059; background: #f3f4f6; border-radius: 6px; padding: 4px 10px; }
      .rec-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; padding-top: 16px; border-top: 1px solid var(--line); }
      .rec-cols h6 { font-size: 11px; color: var(--ash-soft); font-weight: 600; letter-spacing: 0.03em; margin-bottom: 9px; }
      .src { display: flex; align-items: center; gap: 7px; font-size: 13px; color: #3b3f47; margin-bottom: 7px; }
      .src .lk { color: var(--signal); }
      .hash { display: flex; align-items: center; gap: 8px; margin-top: 16px; background: var(--mist); border: 1px solid var(--line); border-radius: var(--r-sm); padding: 9px 12px; font-family: ui-monospace, "SF Mono", Menlo, monospace; font-size: 12px; color: #4b5059; overflow: hidden; }
      .hash .key { color: var(--ash-soft); }
      .timeline { margin-top: 18px; padding-top: 16px; border-top: 1px solid var(--line); }
      .timeline h6 { font-size: 11px; color: var(--ash-soft); font-weight: 600; margin-bottom: 11px; }
      .tl { display: flex; align-items: center; gap: 10px; font-size: 13px; color: #3b3f47; padding: 5px 0; }
      .tl .who { width: 22px; height: 22px; border-radius: 50%; background: #eef0f3; color: #6b7280; font-size: 10px; font-weight: 700; display: grid; place-items: center; flex: none; }
      .tl .when { margin-left: auto; font-size: 11.5px; color: var(--ash-soft); font-family: ui-monospace, monospace; }

      /* ---------- stats section ---------- */
      .stats-head { max-width: 560px; margin-bottom: 38px; }
      .stats-head h2 { font-size: clamp(24px, 3.4vw, 34px); font-weight: 800; letter-spacing: -0.025em; line-height: 1.32; }
      .stats-head p { color: var(--ash); margin-top: 14px; font-size: 16px; }
      .chart-card { border: 1px solid var(--line); border-radius: var(--r-lg); background: #fff; padding: 24px; box-shadow: var(--shadow-soft); }
      .chart-legend { display: flex; gap: 20px; margin-bottom: 8px; font-size: 13px; color: var(--ash); }
      .chart-legend span { display: flex; align-items: center; gap: 7px; }
      .chart-legend .ln { width: 16px; height: 2px; border-radius: 2px; }
      .chart svg { width: 100%; height: auto; display: block; }
      .x-axis { display: flex; justify-content: space-between; font-size: 11.5px; color: var(--ash-soft); margin-top: 6px; }
      .x-axis .eday { color: var(--signal); font-weight: 600; white-space: nowrap; }
      .dist-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; margin-top: 18px; }
      .dist h5 { font-size: 15px; font-weight: 700; margin-bottom: 16px; }
      .bar-row { margin-bottom: 14px; }
      .bar-row .top { display: flex; justify-content: space-between; font-size: 13.5px; color: #3b3f47; margin-bottom: 6px; }
      .bar-row .top b { font-weight: 600; color: var(--ink); }
      .track { height: 7px; border-radius: 999px; background: #f1f2f4; overflow: hidden; }
      .fill { height: 100%; border-radius: 999px; background: var(--signal); width: 0; transition: width 1s var(--ease); }

      /* ---------- final cta ---------- */
      .final { padding: 84px 0; }
      .final-box { background: var(--ink); border-radius: var(--r-lg); color: #fff; text-align: center; padding: 64px 28px; }
      .final-box h2 { font-size: clamp(26px, 4vw, 40px); font-weight: 800; line-height: 1.3; letter-spacing: -0.025em; }
      .final-box p { color: rgba(255, 255, 255, 0.66); margin: 18px auto 0; max-width: 480px; font-size: 16px; }
      .final-box .cta { display: flex; gap: 12px; justify-content: center; margin-top: 32px; flex-wrap: wrap; }

      /* ---------- footer ---------- */
      footer { border-top: 1px solid var(--line); padding: 56px 0 40px; }
      .foot { display: grid; grid-template-columns: 1.6fr 1fr 1fr; gap: 32px; }
      .foot .brand { margin-bottom: 14px; }
      .foot p { font-size: 13.5px; color: var(--ash); max-width: 330px; line-height: 1.7; }
      .foot h6 { font-size: 12px; color: var(--ash-soft); font-weight: 700; letter-spacing: 0.04em; margin-bottom: 14px; }
      .foot ul { list-style: none; }
      .foot li { margin-bottom: 10px; font-size: 14px; color: #4b5059; }
      .foot li a:hover { color: var(--signal); }
      .notice { margin-top: 44px; padding-top: 24px; border-top: 1px solid var(--line); font-size: 12.5px; color: var(--ash-soft); line-height: 1.8; }
      .notice b { color: var(--ash); font-weight: 600; }

      /* ---------- reveal ---------- */
      .reveal { opacity: 0; transform: translateY(20px); transition: opacity 0.7s var(--ease), transform 0.7s var(--ease); }
      .reveal.in { opacity: 1; transform: none; }

      /* ---------- responsive ---------- */
      @media (max-width: 900px) {
        /* nav 항목 숨김 중: 햄버거 메뉴 대신 제보하기 버튼은 모바일에서도 노출. */
        .menu { display: none; }
        .hamb { display: flex; }
        .nav-right { gap: 0; }
        header.open .menu { display: flex; position: absolute; top: 64px; left: 0; right: 0; flex-direction: column; gap: 0; background: #fff; border-bottom: 1px solid var(--line); padding: 8px 24px 16px; align-items: stretch; }
        header.open .menu a { padding: 12px 0; border-bottom: 1px solid var(--line); }
        header.open .menu .btn { display: inline-flex; margin-top: 12px; }
        .grid-2 { grid-template-columns: 1fr; }
        .verify { grid-template-columns: 1fr; gap: 40px; }
        .foot { grid-template-columns: 1fr 1fr; }
        .foot .about { grid-column: 1 / -1; }
      }
      @media (max-width: 680px) {
        .section { padding: 60px 0; }
        .hero { padding: 60px 0 40px; }
        .stat-grid { grid-template-columns: 1fr 1fr; }
        .mock-body { grid-template-columns: 1fr; }
        .side { display: none; }
        .rec-cols { grid-template-columns: 1fr; }
        .dist-grid { grid-template-columns: 1fr; }
        .final-box { padding: 48px 22px; }
      }
      @media (prefers-reduced-motion: reduce) {
        * { scroll-behavior: auto !important; }
        .reveal { opacity: 1; transform: none; transition: none; }
        .fill { transition: none; }
      }
    </style>
  </head>
  <body>
    <header id="hd">
      <div class="wrap nav">
        <a href={import.meta.env.BASE_URL} class="brand"><span class="mark">V</span>Votatis</a>
        <nav class="menu">
          {/* 상단 섹션 내비 — 지금은 숨김(나중에 복원). 관련 섹션이 갖춰지면 되살린다.
          <a href="#archive">공개 아카이브</a>
          <a href="#verify">검증 시스템</a>
          <a href="#stats">제보</a>
          <a href="#footer">설계 원칙</a>
          */}
          <a href={reportHref} class="btn btn-primary btn-sm">제보하기</a>
        </nav>
        <div class="nav-right">
          <a href={reportHref} class="btn btn-primary btn-sm">제보하기</a>
          {/* 햄버거(모바일 메뉴) 버튼 — nav 항목을 숨긴 동안 함께 숨김(나중에 복원).
          <button class="hamb" id="hamb" aria-label="메뉴 열기"><span></span></button>
          */}
        </div>
      </div>
    </header>

    <!-- HERO -->
    <section class="hero">
      <div class="wrap">
        <span class="eyebrow reveal"><span class="dot"></span>사람이 검증하는 공개 기록</span>
        <h1 class="reveal">선거 현장의 제보를 출처와 함께 모으고,<br />사람이 검증한 결과만 아카이브로 남깁니다.</h1>
        <p class="reveal">접수된 제보는 사실이 아니라 검증 대상인 주장으로 다룹니다. 모든 기록에는 검증 상태가 함께 표시되고, 반박된 내용도 그대로 남습니다.</p>
        <div class="cta reveal">
          <a href={reportHref} class="btn btn-primary">제보 보내기</a>
          <a href="#archive" class="btn btn-ghost">아카이브 둘러보기</a>
        </div>

        <!-- DASHBOARD MOCK -->
        <div class="mock-shell reveal" id="archive">
          <div class="mock-bar">
            <div class="lights"><i></i><i></i><i></i></div>
            <div class="addr">votatis.kr/archive</div>
          </div>
          <div class="mock-body">
            {/* 사이드바 — 지금은 숨김(나중에 복원). 함께 .mock-body grid 도 208px 1fr 로 되돌릴 것.
            <aside class="side">
